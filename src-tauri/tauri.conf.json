{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "SwiftEdge",
  "version": "0.1.0",
  "identifier": "com.swiftedge.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "SwiftEdge",
        "label": "main",
        "width": 392,
        "height": 860,
        "resizable": false,
        "fullscreen": false,
        "focus": false,
        "focusable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "visibleOnAllWorkspaces": true,
        "skipTaskbar": true,
        "visible": true,
        "shadow": true,
        "acceptFirstMouse": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
